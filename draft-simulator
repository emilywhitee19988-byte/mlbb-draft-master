<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🎯 HOK Draft Simulator</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #1e3a8a 0%, #1e293b 100%);
      color: #e2e8f0;
      min-height: 100vh;
      padding: 20px;
    }
    .container { max-width: 1400px; margin: 0 auto; }
    .header {
      text-align: center;
      margin-bottom: 30px;
      padding: 20px;
      background: rgba(30, 41, 59, 0.8);
      border-radius: 15px;
      border: 2px solid #3b82f6;
    }
    .header h1 { font-size: 2.5rem; margin-bottom: 10px; }
    .draft-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .panel {
      background: rgba(30, 41, 59, 0.6);
      padding: 20px;
      border-radius: 15px;
      border: 2px solid #334155;
    }
    .panel h2 { color: #60a5fa; margin-bottom: 15px; }
    .role-buttons { display: flex; gap: 10px; flex-wrap: wrap; margin: 15px 0; }
    .role-btn {
      padding: 12px 24px;
      background: #1e293b;
      border: 2px solid #334155;
      border-radius: 8px;
      color: #94a3b8;
      cursor: pointer;
      font-weight: 600;
    }
    .role-btn.active {
      background: #3b82f6;
      border-color: #3b82f6;
      color: white;
    }
    .hero-select {
      width: 100%;
      padding: 12px;
      background: #1e293b;
      border: 2px solid #334155;
      border-radius: 8px;
      color: #e2e8f0;
      font-size: 1rem;
      margin: 10px 0;
    }
    @media (max-width: 768px) {
      .draft-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
