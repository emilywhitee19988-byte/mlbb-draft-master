    </div>
    
    <div class="draft-grid">
      <div class="panel">
        <h2>👤 Your Pick</h2>
        <div class="role-buttons">
          <button class="role-btn" onclick="selectRole('Tank')">Tank</button>
          <button class="role-btn" onclick="selectRole('Fighter')">Fighter</button>
          <button class="role-btn" onclick="selectRole('Assassin')">Assassin</button>
          <button class="role-btn" onclick="selectRole('Mage')">Mage</button>
          <button class="role-btn" onclick="selectRole('Marksman')">Marksman</button>
          <button class="role-btn" onclick="selectRole('Support')">Support</button>
        </div>
        <div id="your-hero-select"></div>
      </div>
      
      <div class="panel">
        <h2>⚔️ Enemy Team</h2>
        <select class="hero-select" id="enemy1" onchange="updateAnalysis()">
          <option value="">Enemy Pick 1</option>
        </select>
        <select class="hero-select" id="enemy2" onchange="updateAnalysis()">
