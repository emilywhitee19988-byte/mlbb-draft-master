    let selectedRole = null;
    
    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
      populateEnemyDropdowns();
      console.log('✅ Draft loaded:', Object.keys(HEROES).length, 'heroes');
    });
    
    function populateEnemyDropdowns() {
      ['enemy1', 'enemy2', 'enemy3', 'enemy4', 'enemy5'].forEach(id => {
        const select = document.getElementById(id);
        Object.values(HEROES).forEach(hero => {
          const opt = document.createElement('option');
          opt.value = hero.id;
          opt.textContent = hero.nameEn + ' (' + hero.role + ')';
          select.appendChild(opt);
        });
      });
    }
    
    function selectRole(role) {
      selectedRole = role;
      document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
      event.target.classList.add('active');
      
      const container = document.getElementById('your-hero-select');
      const roleHeroes = Object.values(HEROES).filter(h => h.role === role);
      
      const select = document.createElement('select');
      select.className = 'hero-select';
      
      const opt = document.createElement('option');
      opt.value = '';
      opt.textContent = 'Choose your ' + role;
      select.appendChild(opt);
      
      roleHeroes.forEach(hero => {
        const opt = document.createElement('option');
        opt.value = hero.id;
        opt.textContent = hero.nameEn + ' (' + hero.tier + ')';
        select.appendChild(opt);
      });
      
      container.innerHTML = '';
      container.appendChild(select);
      updateAnalysis();
    }
    
    function updateAnalysis() {
      const enemyIds = [];
      ['enemy1', 'enemy2', 'enemy3', 'enemy4', 'enemy5'].forEach(id => {
        const val = document.getElementById(id).value;
        if (val) enemyIds.push(val);
      });
      
      const container = document.getElementById('suggestions');
      
      if (!selectedRole || enemyIds.length === 0) {
        container.innerHTML = '<h4 style="color: #10b981;">💡 Select role and pick enemies</h4>';
        return;
      }
      
      // Get suggestions
      const suggestions = getCounterSuggestions(selectedRole, enemyIds);
      
      if (suggestions.length === 0) {
        container.innerHTML = '<h4 style="color: #10b981;">💡 No counters found</h4>';
        return;
      }
      
      let html = '<h4 style="color: #10b981;">💡 Top Suggestions</h4>';
      suggestions.slice(0, 5).forEach((s, i) => {
        const hero = HEROES[s.id];
        const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '⭐';
        html += '<div style="background: rgba(51,65,85,0.6); padding: 10px; margin: 8px 0; border-radius: 8px;">';
        html += medal + ' <strong>' + hero.nameEn + '</strong> (Score: ' + s.score + ')';
        html += '</div>';
      });
      
      container.innerHTML = html;
      
      // Also show build advice
      analyzeBuildAdvice(enemyIds);
    }
    
    function getCounterSuggestions(role, enemyIds) {
      const roleHeroes = Object.values(HEROES).filter(h => h.role === role);
      
      const scored = roleHeroes.map(hero => {
        let score = 0;
        
        if (hero.counters) {
          Object.keys(hero.counters).forEach(lane => {
            const laneCounters = hero.counters[lane];
            if (laneCounters && laneCounters.strong) {
              laneCounters.strong.forEach(cid => {
                if (enemyIds.includes(cid)) score += 3;
              });
            }
          });
        }
        
        if (hero.tier === 'S') score += 2;
        if (hero.tier === 'A') score += 1;
        
        return { id: hero.id, score: score };
      });
      
      scored.sort((a, b) => b.score - a.score);
      return scored.filter(s => s.score > 0);
    }
  
    
    function analyzeBuildAdvice(enemyIds) {
      if (!selectedRole || enemyIds.length === 0) {
        document.getElementById('build-advice').style.display = 'none';
        return;
      }
      
      document.getElementById('build-advice').style.display = 'block';
      
      const enemies = enemyIds.map(id => HEROES[id]).filter(h => h);
      const warnings = [];
      
      // Detect healers
      const healers = ['caiyan', 'yao', 'dolia', 'ming', 'guiguzi', 'daqiao'];
      const enemyHealers = enemies.filter(e => healers.includes(e.id));
      
      if (enemyHealers.length >= 2) {
        warnings.push({
          title: '❗❗ MULTIPLE HEALERS (' + enemyHealers.length + ')',
          advice: 'RUSH ANTI-HEAL IN FIRST 2 ITEMS!',
          items: ['Deadly Blade', 'Nightmare Touch']
        });
      } else if (enemyHealers.length === 1) {
        warnings.push({
          title: '❗ HEALER DETECTED',
          advice: 'Get Anti-Heal Item',
          items: ['Deadly Blade (Physical)', 'Nightmare Touch (Magical)']
        });
      }
      
      // Detect multiple tanks
      const tanks = enemies.filter(e => e.role === 'Tank');
      if (tanks.length >= 2) {
        warnings.push({
          title: '❗ MULTIPLE TANKS (' + tanks.length + ')',
          advice: 'Stack Penetration',
          items: ['Void Staff', 'Shadow Tomahawk', 'Armor Breaker']
        });
      }
      
      // Detect multiple mages
      const mages = enemies.filter(e => e.role === 'Mage');
      if (mages.length >= 2) {
        warnings.push({
          title: '❗ MULTIPLE MAGES (' + mages.length + ')',
          advice: 'Build Magic Defense',
          items: ['Athena Buckler', 'Witch Cape']
        });
      }
      
      // Detect multiple assassins
      const assassins = enemies.filter(e => e.role === 'Assassin');
      if (assassins.length >= 2) {
        warnings.push({
          title: '❗ MULTIPLE ASSASSINS (' + assassins.length + ')',
          advice: 'Get Armor + HP Early',
          items: ['Guardian Armor', 'Thornmail']
        });
      }
      
      // Display warnings
      const container = document.getElementById('build-content');
      
      if (warnings.length === 0) {
        container.innerHTML = '<p style="color: #94a3b8;">No specific threats. Build standard items for your role.</p>';
        return;
      }
      
      let html = '';
      warnings.forEach(w => {
        html += '<div style="background: rgba(239,68,68,0.15); padding: 10px; margin: 8px 0; border-radius: 8px; border-left: 3px solid #ef4444;">';
        html += '<div style="color: #ef4444; font-weight: 600;">' + w.title + '</div>';
        html += '<div style="color: #e2e8f0; margin-top: 4px;">→ ' + w.advice + '</div>';
        if (w.items) {
          html += '<div style="margin-top: 6px;">';
          w.items.forEach(item => {
            html += '<span style="background: rgba(239,68,68,0.2); padding: 3px 8px; margin-right: 5px; border-radius: 6px; font-size: 0.85rem; color: #fca5a5;">' + item + '</span>';
          });
          html += '</div>';
        }
        html += '</div>';
      });
      
      container.innerHTML = html;
    }

