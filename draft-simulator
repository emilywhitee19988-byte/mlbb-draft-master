        <div id="suggestions" style="margin-top: 20px; padding: 15px; background: rgba(16,185,129,0.1); border-radius: 10px;">
          <h4 style="color: #10b981;">💡 Pick enemies to see suggestions</h4>
        </div>
        
        <div id="build-advice" style="margin-top: 20px; padding: 15px; background: rgba(251,191,36,0.1); border-radius: 10px; border: 2px solid rgba(251,191,36,0.3); display: none;">
          <h4 style="color: #fbbf24; margin-bottom: 10px;">⚔️ Build Advice</h4>
          <div id="build-content"></div>
        </div>
      </div>
